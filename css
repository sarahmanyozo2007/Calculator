body{
    margin:0;
    padding:0;
    font-family: Arial, Helvetica, sans-serif;
    background-color:#e5e5e5;
}
.calculator-section{
    display:flex;
    justify-content:center;
    margin-top:80px;
}
.calculator-wrapper{
    background-color:grey;
    width:320px;
    padding:20px;
    border-radius:15px;
    display:flex;
    flex-direction:column;
    align-items:center;
}
.logo{
    font-size:2rem;
    margin-bottom:20px;
}
#display{
    width:280px;
    height:45px;
    border:none;
    margin-bottom:20px;
    padding-left:10px;
    font-size:20px;
}
